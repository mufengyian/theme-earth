---
import Layout from "../layouts/Layout.astro";
---
<Layout>
  <Fragment slot="head">
    <title th:text="|${singlePage.spec.title} - ${site.title}|"></title>
  </Fragment>
  <th:block th:replace="~{modules/article-layout :: article-layout(article = ${singlePage}, kind = 'page', tocMode = 'none', showSidebar = ${theme.config.sidebar?.show_on_page ?: false}, postDisplay = ${theme.config.post.post_display}, shareIds = ${theme.config.post.share_item_ids})}" />
</Layout>
